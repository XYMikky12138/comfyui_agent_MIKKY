# RunningHub Agent 插件配置
# 此文件包含 API Key 等敏感信息，请勿提交到版本控制系统

# RunningHub API Key（必填）
RH_API_KEY=your_runninghub_api_key_here

# RunningHub API 基础地址（可选，默认值如下）
RH_API_BASE_URL=https://www.runninghub.cn/openapi/v2

# SiliconFlow API Key（可选，用于 VLM 智能验证功能）
VLM_API_KEY=your_siliconflow_api_key_here

# API 请求超时（秒）
RH_API_TIMEOUT=60

# 轮询间隔（秒）
RH_API_POLLING_INTERVAL=5

# 最大轮询时间（秒）
RH_API_MAX_POLLING_TIME=600

# 上传超时（秒）
RH_UPLOAD_TIMEOUT=60

